# DO NOT commit real values — this file is a template only.
# Create the secret with:
#
#   oc create secret generic ai-factory-secrets \
#     --from-literal=AUTH_PASSWORD_HASH='$2b$10$...' \
#     --from-literal=SESSION_SECRET='change-me-to-random-string' \
#     --from-literal=GOOGLE_API_KEY='your-google-api-key' \
#     -n ai-factory
#
apiVersion: v1
kind: Secret
metadata:
  name: ai-factory-secrets
  namespace: ai-factory
type: Opaque
stringData:
  AUTH_PASSWORD_HASH: "REPLACE_ME"
  SESSION_SECRET: "REPLACE_ME"
  GOOGLE_API_KEY: "REPLACE_ME"
