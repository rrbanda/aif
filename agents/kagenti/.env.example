# LLM configuration (LiteLLM via LlamaStack or any OpenAI-compatible endpoint)
LLM_MODEL=openai/gemini/models/gemini-2.5-flash
LLM_API_BASE=http://localhost:8000/v1
LLM_API_KEY=not-needed

# A2A agent endpoint (used in AgentCard for discovery)
AGENT_ENDPOINT=http://localhost:8000/

# RHDH backend URL for content/config/data tools
CONTENT_API_URL=http://localhost:7007/api/aifactory

# Local content directory fallback (for file-based tools like account, deliverable, etc.)
# Leave blank to rely only on CONTENT_API_URL for remote content
CONTENT_DIR=

# Required by litellm (set to any value if LlamaStack doesn't need a real key)
OPENAI_API_KEY=not-needed

# Logging level
LOG_LEVEL=INFO
