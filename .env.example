# Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=$2b$10$... # Generate with: node -e "require('bcrypt').hash('yourpassword', 10).then(console.log)"
SESSION_SECRET=change-this-to-a-random-string

# LLM API (for AI Assistant - Plan 3)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=openai  # openai | anthropic

# Content
CONTENT_DIR=../content

# Server
PORT=3001
NODE_ENV=development

# ADK Agent Server
# ADK_BASE_URL=http://localhost:8000    # Override for OpenShift: http://agent:8000
# ADK_PORT=8000
